:8080 {
	# Redirect GET requests to password reset endpoint to the frontend
	@password_reset_get {
		method GET
		path /api/v1/auth/password/reset
	}
	redir @password_reset_get https://buildersmty.com.mx/auth/reset-password?token={query.token} 302

	# Proxy everything else to shark-auth
	reverse_proxy localhost:8081
}
